# Instance hostnames (dagster.gavin, etc.) come from the generated zone file.
# Control-plane hosts (api, app) are NOT in the zone — fallthrough forwards them
# to public DNS (Cloudflare) so the SPA and API keep working on the tailnet.
myhomecloud.dev {
    file /etc/coredns/db.myhomecloud.dev myhomecloud.dev {
        fallthrough
    }
    forward . 1.1.1.1 9.9.9.9
    cache 30
    log
    errors
}
