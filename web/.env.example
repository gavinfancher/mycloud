# Clerk publishable key (public). Pull the real value with `clerk env pull`,
# which writes it to .env.local (gitignored).
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Base URL of the controller API. Leave empty in dev (the Vite proxy in
# vite.config.ts forwards /api and /auth to http://localhost:8080).
# In production set to the tunnel host, e.g. https://api.myhomecloud.dev
VITE_API_BASE=
