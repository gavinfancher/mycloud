# Proxmox (API from container — use tailnet IP or LAN IP of pve)
PROXMOX_HOST=100.106.79.65
PROXMOX_USER=root@pam
PROXMOX_TOKEN_NAME=homecloud
PROXMOX_TOKEN_VALUE=
PROXMOX_VERIFY_SSL=false
PROXMOX_NODE=pve-root
PROXMOX_STORAGE=ssd-pool
PROXMOX_SSH_HOST=pve
PROXMOX_BASE_TEMPLATE_ID=9000

# Tailscale — instances join tailnet; SSH via MagicDNS (name.your-tailnet.ts.net)
TAILSCALE_API_KEY=
TAILSCALE_TAILNET=kudu-cliff.ts.net
TAILSCALE_AUTH_KEY=

VM_SSH_USER=ubuntu

# Controller listen address (AGENT_HOST / AGENT_PORT are still accepted for back-compat)
CONTROLLER_HOST=0.0.0.0
CONTROLLER_PORT=8080

# Public domain for the control plane
DOMAIN=myhomecloud.dev

# Cloudflare — needed for Phases 03/04; leave empty for local/dev runs
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_CNAME=

# Caddy reverse proxy — needed for Phase 04; leave empty for local/dev runs
CADDY_CONFIG_DIR=/etc/caddy/sites
CADDY_RELOAD_CMD=

# CoreDNS split DNS — needed for Phase 06; leave empty for local/dev runs
COREDNS_ZONE_PATH=/etc/coredns/db.myhomecloud.dev
COREDNS_RELOAD_CMD=
CONTROL_NODE_TAILSCALE_IP=

# Default primary web port for an instance's base hostname
DEFAULT_WEB_PORT=80
