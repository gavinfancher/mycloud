# Proxmox (API from container — use tailnet IP or LAN IP of pve)
PROXMOX_HOST=100.106.79.65
PROXMOX_USER=root@pam
PROXMOX_TOKEN_NAME=homecloud
PROXMOX_TOKEN_VALUE=
PROXMOX_VERIFY_SSL=false
PROXMOX_NODE=pve-root
PROXMOX_STORAGE=ssd-pool
PROXMOX_SSH_HOST=pve
PROXMOX_BASE_TEMPLATE_ID=9000

# Tailscale — instances join tailnet; SSH via MagicDNS (name.your-tailnet.ts.net)
TAILSCALE_API_KEY=
TAILSCALE_TAILNET=kudu-cliff.ts.net
TAILSCALE_AUTH_KEY=

VM_SSH_USER=ubuntu

# Controller listen address (AGENT_HOST / AGENT_PORT are still accepted for back-compat)
CONTROLLER_HOST=0.0.0.0
CONTROLLER_PORT=8080

# Public domain for the control plane
DOMAIN=myhomecloud.dev

# Cloudflare — needed for Phases 03/04; leave empty for local/dev runs
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_CNAME=
# Cloudflare Tunnel connector token (from `cloudflared tunnel token <name>`)
# Used by the cloudflared container in docker-compose.yml.
CLOUDFLARE_TUNNEL_TOKEN=

# Caddy reverse proxy — needed for Phase 04; leave empty for local/dev runs
# CADDY_CONFIG_DIR: directory where the controller writes per-host *.caddy files
#   (mounted as the caddy_sites volume in docker-compose)
CADDY_CONFIG_DIR=/etc/caddy/sites
# CADDY_RELOAD_CMD: Caddy admin API base URL; the controller POSTs to
#   {CADDY_RELOAD_CMD}/reload after writing a site file.
#   Set to http://caddy:2019 when running in docker-compose; leave empty for
#   local/dev runs (site files accumulate but no live reload occurs).
CADDY_RELOAD_CMD=

# CoreDNS split DNS — needed for Phase 06; leave empty for local/dev runs
COREDNS_ZONE_PATH=/etc/coredns/db.myhomecloud.dev
COREDNS_RELOAD_CMD=
CONTROL_NODE_TAILSCALE_IP=

# Default primary web port for an instance's base hostname
DEFAULT_WEB_PORT=80

# Owner username (single-user model). Namespaces public hostnames as
# <service>.<instance>.<OWNER_USERNAME>.<DOMAIN>. Leave empty for the flat
# <service>.<instance>.<DOMAIN> scheme. (Phase 12)
OWNER_USERNAME=

# Clerk auth (phase 09). When CLERK_JWKS_URL + CLERK_ISSUER are set, every
# /api/* call and every published app (via forward-auth) requires a valid Clerk
# session. Leave empty for local/dev (auth disabled, logged loudly).
#   JWKS:  https://<your-slug>.clerk.accounts.dev/.well-known/jwks.json
#   ISSUER: https://<your-slug>.clerk.accounts.dev
CLERK_JWKS_URL=
CLERK_ISSUER=
# Comma-separated allowed `azp` parties (your SPA origins), e.g.
#   https://app.myhomecloud.dev
CLERK_AUTHORIZED_PARTIES=
# Publishable key — public, surfaced to the SPA via GET /api/config.
CLERK_PUBLISHABLE_KEY=

# Frontend / API exposure (phases 09–11)
# Comma-separated CORS origins allowed to call the API (the Pages SPA origin).
FRONTEND_ORIGIN=
# Public host the API is exposed at via the tunnel, e.g. api.myhomecloud.dev
API_PUBLIC_HOST=
# Console URL the forward-auth gate redirects unauthenticated browsers to.
CONSOLE_URL=

# Caddy forward-auth (phase 11). When set, every published site is gated by a
# forward_auth to {upstream}/auth/verify. Use the controller's compose name.
CADDY_FORWARD_AUTH_UPSTREAM=
